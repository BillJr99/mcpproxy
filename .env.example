# Display name reported by the MCP server
MCP_SERVER_NAME=mcpproxy

# Path to tool YAML directory
# Docker → /app/config/tools (set by docker-compose.yml)
# Local  → overridden automatically by run_local.sh
MCP_TOOL_CONFIG_DIR=/app/config/tools

# Required by tool 'personalcapital_get_accounts' — maps to parameter 'email'
# Required by tool 'personalcapital_get_transactions' — maps to parameter 'email'
PERSONALCAPITAL_EMAIL=replace-me

# Required by tool 'personalcapital_get_accounts' — maps to parameter 'password'
# Required by tool 'personalcapital_get_transactions' — maps to parameter 'password'
PERSONALCAPITAL_PASSWORD=replace-me
