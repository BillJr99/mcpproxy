# Display name reported by the MCP server
MCP_SERVER_NAME=mcpproxy

# Path to tool YAML directory (Docker default shown; overridden by run_local.sh locally)
MCP_TOOL_CONFIG_DIR=/app/tools

# Path for cloned external repos (repo: block in YAML)
MCP_REPOS_DIR=/app/repos

# Tool secrets are declared in each tool YAML file under secrets.env.
# Add those variables here or use the web UI Secrets manager at http://localhost:8889.
# Example:
#   MY_API_KEY=replace-me
